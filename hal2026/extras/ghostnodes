# MENU PRINCIPAL
# ══════════════════════════════════════════════════════════════════════════════

menu_principal() {
    while true; do
        banner

        # ── Linha de status rápido ────────────────────────────────────────────
        HOSTNAME_NOW=$(hostname 2>/dev/null || echo "—")
        UPTIME_NOW=$(uptime -p 2>/dev/null | sed 's/up //' || echo "—")
        USER_NOW="${SUDO_USER:-$(whoami)}"
        printf "  ${DIM}Node: ${WHITE}%-15s${RESET}  ${DIM}Up: %-20s${RESET}  ${DIM}User: %s${RESET}\n\n" \
               "$HOSTNAME_NOW" "$UPTIME_NOW" "$USER_NOW"

        sep
        printf "  ${BOLD}${WHITE}Menu Principal${RESET}\n"
        sep
        echo ""
        printf "  ${BOLD}${CYAN}[1]${RESET}  ${BOLD}Sistema${RESET}              ${DIM}Verificação, serviços, configurações e atualizações${RESET}\n"
        printf "  ${BOLD}${CYAN}[2]${RESET}  ${BOLD}Conexões de Rede${RESET}     ${DIM}Status Wi-Fi, conexão e diagnóstico de interfaces${RESET}\n"
        printf "  ${BOLD}${CYAN}[3]${RESET}  ${BOLD}Docker${RESET}               ${DIM}Verificação, instalação e configuração de containers${RESET}\n"
        echo ""
        sep_thin
        echo ""
        printf "  ${BOLD}${YELLOW}[4]${RESET}  ${BOLD}Reiniciar o Node${RESET}     ${DIM}Reinicia o sistema com confirmação${RESET}\n"
        printf "  ${BOLD}${RED}[5]${RESET}  ${BOLD}Desligar o Node${RESET}      ${DIM}Desliga o sistema com confirmação${RESET}\n"
        echo ""
        sep
        printf "  ${BOLD}[q]${RESET}  Sair\n"
        sep
        echo ""
        printf "  ${BOLD}Opção:${RESET} "
        read -r OPT

        case "$OPT" in
            1) menu_sistema ;;
            2) menu_rede ;;
            3) menu_docker ;;
            4) acao_reiniciar ;;
            5) acao_desligar ;;
            q|Q|0) printf "\n  ${DIM}Saindo do ghostnode...${RESET}\n\n"; exit 0 ;;
            "") : ;;  # ENTER sem input recarrega o menu
            *)  step_warn "Opção inválida"; sleep 1 ;;
        esac
    done
}

