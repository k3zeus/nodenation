# 2.3 ─────────────────────────────────────────────────────────────────────────
menu_rede_diagnostico() {
    banner
    section "2.3 — Verificação e Diagnóstico de Interfaces"
    log_section "Rede - Diagnóstico"
    echo ""

    ERROS=0

    # ── Lista todas as interfaces ─────────────────────────────────────────────
    printf "  ${BOLD}Interfaces de rede:${RESET}\n\n"
    printf "  ${BOLD}${CYAN}%-12s %-8s %-20s %s${RESET}\n" "Interface" "Estado" "IP" "MAC"
    sep_thin

    ip -o link show 2>/dev/null | while IFS= read -r LINE; do
        IFACE=$(echo "$LINE" | awk '{print $2}' | tr -d ':')
        STATE=$(echo "$LINE" | grep -o "state [A-Z]*" | awk '{print $2}')
        MAC=$(echo "$LINE" | grep -o "link/ether [^ ]*" | awk '{print $2}')
        IP=$(ip -o -4 addr show "$IFACE" 2>/dev/null | awk '{print $4}' | head -1)
        [ -z "$IP" ] && IP="—"
        [ -z "$MAC" ] && MAC="—"

        case "$STATE" in
            UP)      SC="${GREEN}UP${RESET}" ;;
            DOWN)    SC="${RED}DOWN${RESET}" ;;
            UNKNOWN) SC="${YELLOW}?${RESET}" ;;
            *)       SC="${DIM}$STATE${RESET}" ;;
        esac

        printf "  ${BULLET} ${BOLD}%-12s${RESET} %-17b %-20s ${DIM}%s${RESET}\n" \
               "$IFACE" "$SC" "$IP" "$MAC"
    done

    echo ""
    sep

    # ── Interfaces wireless especificamente ──────────────────────────────────
    printf "  ${BOLD}Interfaces wireless (iw):${RESET}\n\n"
    if command -v iw &>/dev/null; then
        iw dev 2>/dev/null | awk '
            /^phy/{phy=$0}
            /Interface/{iface=$2}
            /ssid/{ssid=$2}
            /channel/{chan=$2}
            /type/{type=$2}
            /addr/{mac=$2; printf "  • %-12s  type=%-12s  ch=%-4s  mac=%s\n", iface, type, chan, mac}
        ' || step_warn "iw não retornou dados de interfaces"
    else
        step_err "iw não instalado"
    fi

    echo ""
    sep

    # ── Interfaces DOWN — tenta levantar ─────────────────────────────────────
    step_info "Verificando interfaces DOWN..."
    IFACES_DOWN=$(ip -o link show 2>/dev/null \
        | awk '/state DOWN/{print $2}' | tr -d ':' \
        | grep -v "^lo$" || true)

    if [ -z "$IFACES_DOWN" ]; then
        step_ok "Nenhuma interface crítica DOWN"
    else
        for IFACE in $IFACES_DOWN; do
            step_warn "Interface DOWN: $IFACE"
            if confirm "Tentar ativar $IFACE?"; then
                ip link set "$IFACE" up 2>/dev/null \
                    && step_ok "$IFACE ativada" \
                    || { step_err "Falha ao ativar $IFACE"; ERROS=$((ERROS+1)); }
            fi
        done
    fi

    # ── Verifica hostapd ─────────────────────────────────────────────────────
    echo ""
    step_info "Verificando hostapd (AP mode)..."
    STATUS_AP=$(systemctl is-active hostapd 2>/dev/null || echo "inativo")
    if [ "$STATUS_AP" = "active" ]; then
        step_ok "hostapd ativo — modo AP funcionando"
    else
        step_warn "hostapd: $STATUS_AP"
        if confirm "Tentar iniciar hostapd?"; then
            systemctl start hostapd 2>/dev/null \
                && step_ok "hostapd iniciado" \
                || { step_err "Falha ao iniciar hostapd — verifique /etc/hostapd/hostapd.conf"; ERROS=$((ERROS+1)); }
        fi
    fi

    # ── Gateway e rotas ───────────────────────────────────────────────────────
    echo ""
    step_info "Rotas de rede:"
    ip route 2>/dev/null | while IFS= read -r R; do
        printf "  ${DIM}%s${RESET}\n" "$R"
    done

    echo ""
    sep
    [ "$ERROS" -gt 0 ] \
        && step_warn "$ERROS problema(s) não resolvido(s) — verifique $LOG_FILE" \
        || step_ok "Diagnóstico concluído"

    log_msg "INFO" "Diagnóstico de rede: ERROS=$ERROS"
    press_enter_or_back
}

# ══════════════════════════════════════════════════════════════════════════════
# MENU 3 — DOCKER
# ══════════════════════════════════════════════════════════════════════════════

menu_docker() {
    while true; do
        banner
        section "3 — Docker"
        echo ""
        printf "  ${BOLD}[3.1]${RESET}  Verificação e Testes\n"
        printf "  ${BOLD}[3.2]${RESET}  Instalação do Ambiente Docker\n"
        printf "  ${BOLD}[3.3]${RESET}  Configurações (.env e containers)\n"
        echo ""
        sep
        printf "  ${BOLD}[0]${RESET}   Voltar\n"
        sep
        echo ""
        printf "  Opção: "
        read -r OPT
        case "$OPT" in
            3.1|31|1) menu_docker_verificacao ;;
            3.2|32|2) menu_docker_instalacao ;;
            3.3|33|3) menu_docker_configuracoes ;;
            0|"")     return ;;
            *)        step_warn "Opção inválida"; sleep 1 ;;
        esac
    done
}

# 3.1 ─────────────────────────────────────────────────────────────────────────
menu_docker_verificacao() {
    banner
    section "3.1 — Verificação e Testes Docker"
    log_section "Docker - Verificação"
    echo ""

    ERROS=0

    # ── Docker daemon ─────────────────────────────────────────────────────────
    step_info "Verificando Docker daemon..."
    if ! command -v docker &>/dev/null; then
        step_err "Docker não instalado — use o menu 3.2 para instalar"
        press_enter_or_back; return
    fi

    DOCKER_STATUS=$(systemctl is-active docker 2>/dev/null || echo "inativo")
    if [ "$DOCKER_STATUS" = "active" ]; then
        DOCKER_VER=$(docker --version 2>/dev/null | cut -d' ' -f3 | tr -d ',')
        step_ok "Docker ativo — versão $DOCKER_VER"
    else
        step_err "Docker daemon: $DOCKER_STATUS"
        ERROS=$((ERROS+1))
        log_msg "ERR" "Docker daemon inativo"
    fi

    # ── Portainer ─────────────────────────────────────────────────────────────
    echo ""
    step_info "Verificando Portainer..."
    if docker ps 2>/dev/null | grep -q "portainer"; then
        PORT_INFO=$(docker ps 2>/dev/null | grep portainer | awk '{print $NF, $(NF-1)}')
        step_ok "Portainer rodando — $PORT_INFO"
        # Verifica porta 9000/9443
        if ss -tlnp 2>/dev/null | grep -qE ":9(000|443)"; then
            step_ok "Porta Portainer acessível (9000/9443)"
        else
            step_warn "Portainer rodando mas porta 9000/9443 não detectada"
        fi
    else
        step_warn "Portainer não encontrado nos containers ativos"
        ERROS=$((ERROS+1))
        log_msg "WARN" "Portainer não encontrado"
    fi

    # ── Containers ────────────────────────────────────────────────────────────
    echo ""
    step_info "Containers ativos:"
    echo ""
    if docker ps 2>/dev/null | grep -qv "CONTAINER"; then
        printf "  ${BOLD}${CYAN}%-20s %-15s %-20s %s${RESET}\n" \
               "Nome" "Status" "Imagem" "Portas"
        sep_thin
        docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Image}}\t{{.Ports}}" \
            2>/dev/null | tail -n +2 | while IFS=$'\t' read -r NAME STATUS IMAGE PORTS; do
            echo "$STATUS" | grep -qi "up" && SC="${GREEN}" || SC="${YELLOW}"
            printf "  ${BULLET} ${BOLD}%-20s${RESET} ${SC}%-15s${RESET} %-20s ${DIM}%s${RESET}\n" \
                   "$NAME" "$STATUS" "$IMAGE" "$PORTS"
        done
    else
        step_warn "Nenhum container ativo"
    fi

    echo ""
    step_info "Containers parados ou com erro:"
    STOPPED=$(docker ps -a --filter "status=exited" --format "{{.Names}} {{.Status}}" 2>/dev/null || true)
    if [ -n "$STOPPED" ]; then
        echo "$STOPPED" | while IFS= read -r L; do
            printf "  ${CROSS} ${DIM}%s${RESET}\n" "$L"
        done
    else
        step_ok "Nenhum container parado"
    fi

    echo ""
    sep
    [ "$ERROS" -gt 0 ] \
        && step_warn "$ERROS problema(s) detectado(s) — use 3.2 ou 3.3 para corrigir" \
        || step_ok "Docker operacional"

    log_msg "INFO" "Verificação Docker: ERROS=$ERROS"
    press_enter_or_back
}

# 3.2 ─────────────────────────────────────────────────────────────────────────
menu_docker_instalacao() {
    banner
    section "3.2 — Instalação do Ambiente Docker"
    log_section "Docker - Instalação"
    echo ""

    run_script "$DOCKER_DIR/docker.sh" "Docker Setup" || true
    press_enter_or_back
}

# 3.3 ─────────────────────────────────────────────────────────────────────────
menu_docker_configuracoes() {
    banner
    section "3.3 — Configurações Docker (.env e containers)"
    log_section "Docker - Configurações"
    echo ""

    # ── Localiza .env ─────────────────────────────────────────────────────────
    ENV_FILE=""
    for F in \
        "$HALFIN_DIR/.env" \
        "$DOCKER_DIR/.env" \
        "$HALFIN_DIR/docker-compose.env"; do
        [ -f "$F" ] && ENV_FILE="$F" && break
    done

    if [ -z "$ENV_FILE" ]; then
        step_warn "Arquivo .env não encontrado nos caminhos padrão:"
        printf "  ${DIM}  %s${RESET}\n" "$HALFIN_DIR/.env" "$DOCKER_DIR/.env"
        echo ""
    else
        step_ok "Arquivo .env encontrado: $ENV_FILE"
        echo ""
        printf "  ${BOLD}Variáveis configuradas:${RESET}\n\n"
        grep -v "^#" "$ENV_FILE" 2>/dev/null \
            | grep "=" \
            | while IFS='=' read -r K V; do
                # Ofusca campos com senha/token/secret
                echo "$K" | grep -qiE "pass|token|secret|key" \
                    && V="••••••••" \
                    || true
                printf "  ${DIM}%-25s${RESET} = ${CYAN}%s${RESET}\n" "$K" "$V"
            done
        echo ""
    fi

    # ── docker-compose ────────────────────────────────────────────────────────
    COMPOSE_FILE=""
    for F in \
        "$HALFIN_DIR/docker-compose.yml" \
        "$DOCKER_DIR/docker-compose.yml" \
        "$HALFIN_DIR/compose.yml"; do
        [ -f "$F" ] && COMPOSE_FILE="$F" && break
    done

    if [ -n "$COMPOSE_FILE" ]; then
        step_ok "docker-compose.yml: $COMPOSE_FILE"

        if command -v docker &>/dev/null && docker compose version &>/dev/null 2>&1; then
            echo ""
            step_info "Serviços definidos no compose:"
            docker compose -f "$COMPOSE_FILE" config --services 2>/dev/null \
                | while IFS= read -r SVC; do
                    printf "  ${BULLET} %s\n" "$SVC"
                done || step_warn "Falha ao ler compose"

            echo ""
            if confirm "Verificar e subir containers ausentes agora?"; then
                sep
                COMPOSE_DIR=$(dirname "$COMPOSE_FILE")
                cd "$COMPOSE_DIR"
                [ -n "$ENV_FILE" ] \
                    && docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" up -d 2>&1 \
                        | while IFS= read -r L; do printf "  ${DIM}%s${RESET}\n" "$L"; done \
                    || docker compose -f "$COMPOSE_FILE" up -d 2>&1 \
                        | while IFS= read -r L; do printf "  ${DIM}%s${RESET}\n" "$L"; done
                sep
                step_ok "docker compose up -d executado"
                log_msg "OK" "docker compose up -d em $COMPOSE_FILE"
            fi
        fi
    else
        step_warn "docker-compose.yml não encontrado — verifique $HALFIN_DIR"
    fi

    press_enter_or_back
}

# ══════════════════════════════════════════════════════════════════════════════
# OPÇÃO 4 — REINICIAR
# ══════════════════════════════════════════════════════════════════════════════

acao_reiniciar() {
    banner
    section "4 — Reiniciar o Node"
    echo ""
    printf "  ${YELLOW}${BOLD}Esta ação irá reiniciar o sistema imediatamente.${RESET}\n"
    echo ""
    if confirm "Confirma o reinício do node?" "n"; then
        log_msg "WARN" "Sistema reiniciado pelo operador via ghostnode"
        step_info "Reiniciando..."
        sleep 1
        reboot
    else
        step_info "Operação cancelada"
        sleep 1
    fi
}

