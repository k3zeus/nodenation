# ══════════════════════════════════════════════════════════════════════════════
# CONFIGURAÇÃO GLOBAL
# ══════════════════════════════════════════════════════════════════════════════
HALFIN_DIR="/home/pleb/halfin"
TOOLS_DIR="$HALFIN_DIR/tools"
DOCKER_DIR="$HALFIN_DIR/docker"
LOG_DIR="$HALFIN_DIR/logs"
LOG_FILE="$LOG_DIR/ghostnode_$(date +%Y%m%d).log"

# ─── Cores e símbolos ─────────────────────────────────────────────────────────
BOLD="\e[1m";    RESET="\e[0m";   DIM="\e[2m"
GREEN="\e[32m";  YELLOW="\e[33m"; RED="\e[31m"
CYAN="\e[36m";   MAGENTA="\e[35m";WHITE="\e[97m"
BLUE="\e[34m";   BG_BLACK="\e[40m"
CHECK="${GREEN}✔${RESET}";  CROSS="${RED}✘${RESET}"
ARROW="${CYAN}▶${RESET}";   WARN="${YELLOW}⚠${RESET}"
BULLET="${DIM}•${RESET}"

# ══════════════════════════════════════════════════════════════════════════════
# HELP — exibido quando chamado com --help ou -h
# ══════════════════════════════════════════════════════════════════════════════
show_help() {
    printf "${BOLD}${CYAN}"
    echo ""
    echo "  ghostnode — Ghost Node Nation Control Center"
    printf "${RESET}"
    echo ""
    printf "  ${BOLD}USO:${RESET}\n"
    printf "    ${CYAN}ghostnode${RESET}           Abre o menu interativo principal\n"
    printf "    ${CYAN}ghostnode --help${RESET}    Exibe esta ajuda\n"
    echo ""
    printf "  ${BOLD}MENU PRINCIPAL:${RESET}\n"
    printf "    ${BOLD}1${RESET}  Sistema         — Verificação, instalações, configurações e atualizações\n"
    printf "    ${BOLD}2${RESET}  Rede            — Status Wi-Fi, conexão e diagnóstico de interfaces\n"
    printf "    ${BOLD}3${RESET}  Docker          — Verificação, instalação e configuração de containers\n"
    printf "    ${BOLD}4${RESET}  Reiniciar       — Reinicia o node com confirmação\n"
    printf "    ${BOLD}5${RESET}  Desligar        — Desliga o node com confirmação\n"
    echo ""
    printf "  ${BOLD}DIRETÓRIOS:${RESET}\n"
    printf "    Base     ${DIM}%s${RESET}\n" "$HALFIN_DIR"
    printf "    Tools    ${DIM}%s${RESET}\n" "$TOOLS_DIR"
    printf "    Docker   ${DIM}%s${RESET}\n" "$DOCKER_DIR"
    printf "    Logs     ${DIM}%s${RESET}\n" "$LOG_DIR"
    echo ""
    printf "  ${BOLD}SCRIPTS UTILIZADOS:${RESET}\n"
    printf "    ${DIM}tools/system.sh         —${RESET} Dados do sistema em tempo real\n"
    printf "    ${DIM}tools/scan_wifi.sh      —${RESET} Escaneamento de redes Wi-Fi\n"
    printf "    ${DIM}tools/wifi_show.sh      —${RESET} Exibição do banco de redes\n"
    printf "    ${DIM}tools/wifi_connect.sh   —${RESET} Conexão interativa a redes\n"
    printf "    ${DIM}docker/docker.sh        —${RESET} Setup do ambiente Docker\n"
    echo ""
    printf "  ${DIM}Ghost Node Nation — Halfin v0.3${RESET}\n"
    echo ""
}

# ══════════════════════════════════════════════════════════════════════════════
# FUNÇÕES DE UI
# ══════════════════════════════════════════════════════════════════════════════

step_ok()   { printf "  ${CHECK} ${WHITE}%s${RESET}\n" "$1"; log_msg "OK" "$1"; }
step_warn() { printf "  ${WARN}  ${YELLOW}%s${RESET}\n" "$1"; log_msg "WARN" "$1"; }
step_err()  { printf "  ${CROSS} ${RED}%s${RESET}\n" "$1"; log_msg "ERR" "$1"; }
step_info() { printf "  ${ARROW} ${DIM}%s${RESET}\n" "$1"; log_msg "INFO" "$1"; }

sep()     { printf "${DIM}  ──────────────────────────────────────────────────────────────${RESET}\n"; }
sep_thin(){ printf "${DIM}  ┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄${RESET}\n"; }

section() {
    echo ""
    printf "${BOLD}${MAGENTA}  ┌─ %s${RESET}\n" "$1"
    sep_thin
}

press_enter() {
    echo ""
    printf "  ${DIM}[ ENTER para continuar ]${RESET}"
    read -r
}

press_enter_or_back() {
    echo ""
    printf "  ${DIM}[ ENTER para voltar ao menu ]${RESET}"
    read -r
}

confirm() {
    local MSG="$1" DEFAULT="${2:-s}"
    local OPTS
    [ "$DEFAULT" = "s" ] \
        && OPTS="${GREEN}${BOLD}S${RESET}/${DIM}n${RESET}" \
        || OPTS="${DIM}s${RESET}/${GREEN}${BOLD}N${RESET}"
    printf "\n  ${YELLOW}?${RESET} %s [%b]: " "$MSG" "$OPTS"
    read -r REPLY
    REPLY="${REPLY:-$DEFAULT}"
    [[ "$REPLY" =~ ^[sS]$ ]]
}

# ══════════════════════════════════════════════════════════════════════════════
# LOG
# ══════════════════════════════════════════════════════════════════════════════
log_msg() {
    local LEVEL="$1"; shift
    mkdir -p "$LOG_DIR" 2>/dev/null || true
    printf "[%s] [%s] %s\n" "$(date '+%F %T')" "$LEVEL" "$*" >> "$LOG_FILE" 2>/dev/null || true
}

log_section() {
    log_msg "---" "════════ $* ════════"
}

# ══════════════════════════════════════════════════════════════════════════════
# BARRA DE STATUS (topo) — temperatura + data/hora
# ══════════════════════════════════════════════════════════════════════════════
status_bar() {
    local TEMP="N/A"
    local DATETIME
    DATETIME=$(date '+%d/%m/%Y  %H:%M:%S')

    # Tenta ler temperatura de múltiplas fontes
    if command -v sensors &>/dev/null; then
        TEMP=$(sensors 2>/dev/null \
            | awk '/^(CPU|temp1|cpu_thermal|Package)/{match($0,/\+([0-9.]+)/,a); if(a[1]!="") {print a[1]"°C"; exit}}')
    fi
    # Fallback: sysfs
    if [ -z "$TEMP" ] || [ "$TEMP" = "N/A" ]; then
        local TFILE
        for TFILE in \
            /sys/class/thermal/thermal_zone0/temp \
            /sys/devices/virtual/thermal/thermal_zone0/temp; do
            [ -f "$TFILE" ] && TEMP="$(( $(cat "$TFILE") / 1000 ))°C" && break
        done
    fi

    printf "${BG_BLACK}"
    printf "  ${DIM}┌────────────────────────────────────────────────────────────┐${RESET}\n"
    printf "  ${DIM}│${RESET}  ${YELLOW}🌡  %-8s${RESET}  ${DIM}│${RESET}  ${CYAN}📅  %-38s${RESET}  ${DIM}│${RESET}\n" \
           "$TEMP" "$DATETIME"
    printf "  ${DIM}└────────────────────────────────────────────────────────────┘${RESET}\n"
}

