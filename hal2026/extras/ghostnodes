# 1.2 ─────────────────────────────────────────────────────────────────────────
menu_sistema_instalacoes() {
    banner
    section "1.2 — Instalações e Status dos Serviços"
    log_section "Sistema - Instalações"
    echo ""

    # Serviços esperados pelo projeto
    SERVICOS="ssh hostapd NetworkManager iptables docker"

    printf "  ${BOLD}%-22s %-12s %-10s %s${RESET}\n" "Serviço" "Status" "Enabled" "Info"
    sep

    for SVC in $SERVICOS; do
        local STATUS ENABLED INFO COLOR

        STATUS=$(systemctl is-active "$SVC" 2>/dev/null || echo "inativo")
        ENABLED=$(systemctl is-enabled "$SVC" 2>/dev/null || echo "disabled")

        case "$STATUS" in
            active)   COLOR="${GREEN}";  INFO="rodando" ;;
            inactive) COLOR="${YELLOW}"; INFO="parado"  ;;
            failed)   COLOR="${RED}";    INFO="FALHA"   ;;
            *)        COLOR="${DIM}";    INFO="$STATUS" ;;
        esac

        printf "  ${BULLET} ${BOLD}%-22s${RESET} ${COLOR}%-12s${RESET} %-10s ${DIM}%s${RESET}\n" \
               "$SVC" "$STATUS" "$ENABLED" "$INFO"
        log_msg "INFO" "Serviço $SVC: status=$STATUS enabled=$ENABLED"
    done

    sep
    echo ""

    # Ferramentas do projeto
    printf "  ${BOLD}Ferramentas do projeto:${RESET}\n\n"
    TOOLS="iw nmcli sqlite3 docker hostapd sensors btop"

    for T in $TOOLS; do
        if command -v "$T" &>/dev/null; then
            VER=$(command "$T" --version 2>/dev/null | head -1 | cut -c1-40 || echo "instalado")
            printf "  ${CHECK} ${BOLD}%-12s${RESET} ${DIM}%s${RESET}\n" "$T" "$VER"
        else
            printf "  ${CROSS} ${BOLD}%-12s${RESET} ${RED}não instalado${RESET}\n" "$T"
        fi
    done

    echo ""
    # Verifica scripts do projeto
    printf "  ${BOLD}Scripts do projeto:${RESET}\n\n"
    SCRIPTS=(
        "$TOOLS_DIR/system.sh"
        "$TOOLS_DIR/wifi_scan.sh"
        "$TOOLS_DIR/wifi_show.sh"
        "$TOOLS_DIR/wifi_connect.sh"
        "$DOCKER_DIR/docker.sh"
    )
    for S in "${SCRIPTS[@]}"; do
        local LABEL="${S/$HALFIN_DIR\//}"
        if [ -f "$S" ]; then
            [ -x "$S" ] \
                && printf "  ${CHECK} ${DIM}%-40s${RESET} ${GREEN}ok${RESET}\n" "$LABEL" \
                || printf "  ${WARN}  ${DIM}%-40s${RESET} ${YELLOW}sem permissão${RESET}\n" "$LABEL"
        else
            printf "  ${CROSS} ${DIM}%-40s${RESET} ${RED}ausente${RESET}\n" "$LABEL"
        fi
    done

    echo ""
    press_enter_or_back
}

# 1.3 ─────────────────────────────────────────────────────────────────────────
menu_sistema_configuracoes() {
    banner
    section "1.3 — Configurações e Correções"
    log_section "Sistema - Configurações"
    echo ""

    ERROS=0

    # ── Permissões dos scripts ────────────────────────────────────────────────
    step_info "Verificando permissões dos scripts..."
    find "$HALFIN_DIR" -name "*.sh" -type f 2>/dev/null | while read -r F; do
        if [ ! -x "$F" ]; then
            chmod +x "$F"
            step_warn "Permissão corrigida: ${F/$HALFIN_DIR\//}"
        fi
    done
    step_ok "Permissões verificadas"

    # ── Hostname ──────────────────────────────────────────────────────────────
    step_info "Verificando hostname..."
    CUR=$(hostname)
    if [ "$CUR" = "halfin" ]; then
        step_ok "Hostname correto: halfin"
    else
        step_warn "Hostname atual: $CUR — corrigindo para 'halfin'..."
        echo "halfin" > /etc/hostname
        hostname halfin
        grep -q "halfin" /etc/hosts \
            || echo "127.0.1.1	halfin" >> /etc/hosts
        step_ok "Hostname corrigido"
        log_msg "WARN" "Hostname corrigido de '$CUR' para 'halfin'"
    fi

    # ── Serviços críticos ─────────────────────────────────────────────────────
    step_info "Verificando e iniciando serviços críticos..."
    for SVC in ssh NetworkManager; do
        STATUS=$(systemctl is-active "$SVC" 2>/dev/null || echo "inativo")
        if [ "$STATUS" != "active" ]; then
            step_warn "$SVC não está ativo — tentando iniciar..."
            systemctl enable --now "$SVC" 2>/dev/null \
                && step_ok "$SVC iniciado" \
                || { step_err "Falha ao iniciar $SVC"; ERROS=$((ERROS+1)); log_msg "ERR" "Falha ao iniciar $SVC"; }
        else
            step_ok "$SVC ativo"
        fi
    done

    # ── ip_forward ────────────────────────────────────────────────────────────
    step_info "Verificando ip_forward..."
    FWD=$(cat /proc/sys/net/ipv4/ip_forward 2>/dev/null || echo "0")
    if [ "$FWD" = "1" ]; then
        step_ok "ip_forward ativo"
    else
        step_warn "ip_forward desativado — corrigindo..."
        echo 1 > /proc/sys/net/ipv4/ip_forward
        grep -q "net.ipv4.ip_forward" /etc/sysctl.conf 2>/dev/null \
            || echo "net.ipv4.ip_forward=1" >> /etc/sysctl.conf
        step_ok "ip_forward ativado"
        log_msg "WARN" "ip_forward foi reativado"
    fi

    # ── DNS básico ────────────────────────────────────────────────────────────
    step_info "Verificando conectividade DNS..."
    if ping -c1 -W3 8.8.8.8 &>/dev/null; then
        step_ok "Internet: alcançável"
    else
        step_err "Internet: sem resposta em 8.8.8.8"
        ERROS=$((ERROS+1))
        log_msg "ERR" "Ping 8.8.8.8 falhou"
    fi
    if host deb.debian.org &>/dev/null; then
        step_ok "DNS: funcionando"
    else
        step_warn "DNS: resolução falhou — verifique /etc/resolv.conf"
        log_msg "WARN" "DNS falhou para deb.debian.org"
    fi

    echo ""
    sep
    if [ "$ERROS" -gt 0 ]; then
        step_warn "$ERROS problema(s) não resolvido(s) automaticamente — verifique os logs em $LOG_FILE"
    else
        step_ok "Todas as verificações concluídas sem erros"
    fi

    press_enter_or_back
}

# 1.4 ─────────────────────────────────────────────────────────────────────────
menu_sistema_atualizacoes() {
    banner
    section "1.4 — Atualizações"
    log_section "Sistema - Atualizações"
    echo ""

    step_info "Verificando atualizações disponíveis..."
    echo ""

    set +e
    apt-get update -qq 2>&1 | while IFS= read -r L; do
        printf "  ${DIM}%s${RESET}\n" "$L"
    done

    UPGRADABLE=$(apt list --upgradable 2>/dev/null | grep -c "/" || true)
    set -e

    if [ "$UPGRADABLE" -eq 0 ]; then
        step_ok "Sistema atualizado — nenhum pacote pendente"
        press_enter_or_back
        return
    fi

    echo ""
    step_info "$UPGRADABLE pacote(s) com atualização disponível:"
    echo ""
    apt list --upgradable 2>/dev/null | grep "/" | while IFS= read -r L; do
        printf "  ${DIM}%s${RESET}\n" "$L"
    done
    echo ""

    if confirm "Realizar atualização agora?"; then
        echo ""
        sep
        log_msg "INFO" "Iniciando apt upgrade ($UPGRADABLE pacotes)"
        set +e
        DEBIAN_FRONTEND=noninteractive apt-get upgrade -y 2>&1 | while IFS= read -r L; do
            if echo "$L" | grep -qiE "^E:|error|fatal"; then
                printf "  ${RED}%s${RESET}\n" "$L"
            else
                printf "  ${DIM}%s${RESET}\n" "$L"
            fi
        done
        RC=${PIPESTATUS[0]}
        set -e
        sep
        echo ""
        [ $RC -eq 0 ] \
            && { step_ok "Atualização concluída"; log_msg "OK" "apt upgrade concluído"; } \
            || { step_err "Atualização retornou erro (RC=$RC)"; log_msg "ERR" "apt upgrade RC=$RC"; }
    else
        step_info "Atualização adiada"
    fi

    press_enter_or_back
}

