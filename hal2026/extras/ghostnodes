# OPÇÃO 5 — DESLIGAR
# ══════════════════════════════════════════════════════════════════════════════

acao_desligar() {
    banner
    section "5 — Desligar o Node"
    echo ""
    printf "  ${RED}${BOLD}Esta ação irá desligar o sistema.${RESET}\n"
    printf "  ${DIM}Certifique-se de que nenhum processo crítico está em andamento.${RESET}\n"
    echo ""
    if confirm "Confirma o desligamento do node?" "n"; then
        log_msg "WARN" "Sistema desligado pelo operador via ghostnode"
        step_info "Desligando..."
        sleep 1
        poweroff
    else
        step_info "Operação cancelada"
        sleep 1
    fi
}

