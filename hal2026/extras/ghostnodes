# ══════════════════════════════════════════════════════════════════════════════
# UTILITÁRIO: executa script externo com fallback
# ══════════════════════════════════════════════════════════════════════════════
run_script() {
    local SCRIPT="$1"
    local DESC="$2"

    log_section "$DESC"

    if [ ! -f "$SCRIPT" ]; then
        step_err "Script não encontrado: $SCRIPT"
        step_info "Verifique se o projeto foi instalado corretamente em $HALFIN_DIR"
        press_enter_or_back
        return 1
    fi

    if [ ! -x "$SCRIPT" ]; then
        step_warn "Script sem permissão de execução — corrigindo..."
        chmod +x "$SCRIPT"
    fi

    echo ""
    sep
    bash "$SCRIPT"
    local RC=$?
    sep
    echo ""

    if [ $RC -ne 0 ]; then
        step_warn "Script finalizado com código de saída: $RC"
        log_msg "WARN" "Script $SCRIPT retornou RC=$RC"
    else
        log_msg "OK" "Script $SCRIPT concluído com sucesso"
    fi

    return $RC
}

