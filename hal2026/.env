# ==================== CAMINHOS GLOBAIS ====================
# Defina aqui a raiz onde todas as pastas dos containers ficarão
USER=pleb
USER_HOME=/home/${USER}
BASEFOLDER=/home/${USER}/halfin
DOCKER=${BASEFOLDER}/docker

# ==================== HEIMDALL ====================
HEIMDALL_PORT=80
HEIMDALL_SSL_PORT=443
HEIMDALL_CONFIG_DIR=${DOCKER}/heimdall/config

# ==================== SYNCTHING ====================
SYNCTHING_PORT=8384
SYNCTHING_USER=admin
SYNCTHING_PASS=Mudar123
SYNCTHING_CONFIG_DIR=${DOCKER}/syncthing/config
SYNCTHING_DATA_DIR=${DOCKER}/syncthing/data
SYNCTHING_OBSIDIAN=${DOCKER}/obsidian
SYNCTHING_KEEPASSXC=${DOCKER}/keepassxc
SYNCTHING_KEEPASSXC=${DOCKER}/keeweb

# ==================== CLOUDFLARED ====================
CLOUDFLARED_TOKEN=seu_token_aqui

# ==================== WIREGUARD (wg-easy) ====================
WG_PORT=51820
WG_UI_PORT=51821
WG_HOST=seudominio.com
WG_PASSWORD=senha_do_ui
WG_ADDRESS=10.8.0.0/24
WG_CONFIG_DIR=${DOCKER}/wireguard

# ==================== NEXTCLOUD ====================
NEXTCLOUD_PORT=8081
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=senha_nextcloud
NEXTCLOUD_CONFIG_DIR=${BASEFOLDER}/nextcloud/config
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=senha_postgres
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=${DOCKER}/postgres/data

# ==================== NGINX ====================
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_CONF_DIR=${DOCKER}/nginx/conf
NGINX_HTML_DIR=${DOCKER}/nginx/html
NGINX_AUTH_DIR=${DOCKER}/nginx/auth
NGINX_AUTH_USER=nginxuser
NGINX_AUTH_PASS=nginxtest

# ==================== UPTIME KUMA ====================
UPTIME_KUMA_PORT=3001
UPTIME_KUMA_DATA_DIR=${DOCKER}/uptimekuma/data

# ==================== KEEPASSXC (Keeweb) ====================
KEEWEB_PORT=8082
KEEWEB_DATA_DIR=${DOCKER}/keeweb/data